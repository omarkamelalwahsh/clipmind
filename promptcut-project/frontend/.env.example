# Copy to ".env" and fill in. Vite only exposes vars prefixed with VITE_.
#
# ⚠️ In this MVP these keys are bundled into the client. That is fine for a local
# demo but exposes them to anyone using the app. For any public deployment, move
# the backend-agent behind a proxy and DELETE these from the frontend.

VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
